{
  "name": "ba6-ai-site",
  "private": true,
  "version": "1.0.0",
  "description": "BA6 AI marketing site. The iOS app lives in /ios.",
  "devDependencies": {
    "tailwindcss": "^3.4.13"
  },
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.js -i src/styles/tailwind.css -o src/styles/tailwind.generated.css --minify",
